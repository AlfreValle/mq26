# .env.demo — Configuración para sesiones de demostración
# Copiar a .env antes de la demo: cp .env.demo .env   (o copy en Windows)

# Modo demo: carga BD sintética con 10 clientes
DEMO_MODE=true
DEMO_DB_PATH=/tmp/mq26_demo.db

# Contraseñas de demo (cambiar antes de producción real)
MQ26_PASSWORD=demo.2026
MQ26_VIEWER_PASSWORD=visor/2026
MQ26_INVESTOR_PASSWORD=inversor+2026

# Usuario administrador demo
MQ26_USER_ADMIN=admin1452

# CCL fallback para demo (actualizar si es necesario)
CCL_FALLBACK=1400.0

# Retail light por defecto para demo
MQ26_RETAIL_LIGHT=1

# Desactivar intentos de BD de usuarios (usar .env passwords)
MQ26_TRY_DB_USERS=false
