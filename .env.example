# MQ26-DSS — Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el .env al repositorio
#
# MVP sólido (sin gasto de nube en BD):
#   - Dejá DATABASE_URL y DB_URL vacíos como abajo → SQLite en 0_Data_Maestra/master_quant.db
#   - MQ26_PASSWORD con al menos 8 caracteres
#   - Verificar: python scripts/mvp_preflight.py
#   - Guía: docs/product/MVP_SOLIDO_RUNBOOK.md

# ── REQUERIDAS ────────────────────────────────────────────────────────────────
# Contraseña de acceso a la terminal (mínimo 8 caracteres).
# Nunca commitear valores reales acá — copiar a .env y personalizar.
MQ26_PASSWORD=cambia_esta_contraseña_por_una_segura
# Login en pantalla: usuario + contraseña (admin / asesor / estudio / inversor por defecto).
MQ26_ADVISOR_PASSWORD=
# MQ26_VIEWER_PASSWORD=   → usuario «estudio»
# MQ26_INVESTOR_PASSWORD= → usuario «inversor» (obligatoria para probar vista retail; puede coincidir con MQ26_PASSWORD en local)
# Opcional: renombrar usuarios de login (minúsculas al comparar)
# MQ26_USER_ADMIN=admin
# MQ26_USER_ESTUDIO=estudio
# MQ26_USER_INVERSOR=inversor
# MQ26_USER_ASESOR=asesor
# Modo SaaS (AUTH_CONFIG): usuarios en esta lista (username en minúsculas) reciben rol viewer.
# MQ26_VIEWERS=invitado1,clienteb
# Modo SaaS: usuarios en esta lista reciben rol inversor.
# MQ26_INVESTORS=cliente1,cliente2
# Modo SaaS: lista de usernames con rol asesor (profesional sin Admin).
# MQ26_ADVISORS=maria,pedro

# Usuarios en SQLite (tablas app_usuarios / app_usuario_cliente): si está activo,
# el login prueba primero la BD y solo si no hay coincidencia usa las contraseñas del .env.
# Alta/gestión: pestaña Admin → «Usuarios BD» (requiere sesión admin).
# MQ26_TRY_DB_USERS=1
# MQ26_TRY_DB_USERS=0   → solo login por .env / AUTH_CONFIG
# MQ26_DB_TENANT_ID=default   → tenant para usuarios y clientes vinculados

# ── BASE DE DATOS (MQ-S3) ─────────────────────────────────────────────────────
# SQLite local (default) — no requiere configuración
# Para PostgreSQL remoto, definir UNA de las siguientes:
#   DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd
#   DB_URL=postgresql://usuario:contraseña@host:5432/nombre_bd
# Ejemplo Supabase: postgresql://postgres.abcxyz:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
DB_URL=

# ── TELEGRAM — alertas del Motor MOD-23 y objetivos por vencer ───────────────
# Las credenciales se almacenan aquí o en la tabla `configuracion` de la BD.
# NO se escriben en os.environ desde la UI (MQ-S1).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── GMAIL — envío de reportes semanales y lectura de comprobantes broker ──────
# GMAIL_USER: tu email de Gmail
# GMAIL_APP_PASSWORD: contraseña de aplicación de 16 letras (NO tu contraseña normal)
#   Cómo generar: myaccount.google.com/security → Contraseñas de aplicaciones → Correo
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=

# ── CONFIGURACIÓN AVANZADA ────────────────────────────────────────────────────
# CCL de respaldo si yfinance falla (actualizar mensualmente)
CCL_FALLBACK_OVERRIDE=1500.0

# TTLs de caché (segundos) — opcional, usar valores por defecto si no se definen
# CACHE_TTL_CCL=300
# CACHE_TTL_HISTORICO=3600
# CACHE_TTL_PRECIOS=300
# CACHE_TTL_METRICAS=60
# CACHE_TTL_DASHBOARD=120

# ── PRODUCCIÓN (Railway + PostgreSQL / Supabase) ─────────────────────────────
# Solo cuando despliegues: UNA sola línea DATABASE_URL (no duplicar más abajo).
# Supabase → Settings → Database → Connection string → Transaction pooler, puerto 6543
# Formato típico: postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres
# Railway inyecta PORT automáticamente (8080 por defecto) — NO definir manualmente
# PORT=8080

# Sentry: monitoreo de errores en producción (opcional pero recomendado)
# Obtener desde: sentry.io → New Project → Python
SENTRY_DSN=

# Auth multi-asesor (Sprint 5): YAML serializado con credenciales de asesores
# Generar hash: python -c "import streamlit_authenticator as s; print(s.Hasher(['pwd']).generate())"
AUTH_CONFIG=
